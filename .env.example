# Postgres
POSTGRES_USER=media
POSTGRES_PASSWORD=changeme
POSTGRES_DB=media_processor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API
API_HOST=0.0.0.0
API_PORT=8000

# Stage 4.5 LLM Patcher — Gemini key pool (ai-core style).
# Comma-separated; rotates on 429 / 5xx. Empty pool disables /drafts/{id}/patch.
LLM_API_KEYS=
LLM_MODEL=gemini-2.5-flash
LLM_TIMEOUT_S=30

# Profile YAML directory (Stage 4.5 reads this when patching).
PROFILES_DIR=profiles

# Pipeline
MEDIA_PROCESSOR_GPU_SERIAL_MODE=1

# Storage — host-side paths bound into containers.
# Defaults below put media + Postgres data inside the repo (.local/, postgres_data named volume).
# To move media + Postgres data onto a separate drive (e.g. an SSD), set absolute host paths.
# Forward slashes work on Windows Docker Desktop, e.g.:
#   MEDIA_STORAGE_DIR=G:/MediaStorage
#   PGDATA_DIR=G:/MediaStorage/pgdata
# MEDIA_STORAGE_DIR=
# PGDATA_DIR=

# In-container paths (read by services). MEDIA_STORAGE_DIR is bind-mounted at /app/media.
MEDIA_ROOT=/app/media
ASSETS_DIR=/app/media/assets
DRAFTS_DIR=/app/media/drafts
UPLOADS_DIR=/app/media/uploads
ANALYSIS_DIR=/app/media/analysis
# M4.6 — ffmpeg-extracted keyframe gallery per Asset; static-served at
# /api/media/thumbnails/{asset_id}/frame_{n}.jpg. On the dispatch host this
# resolves to G:\MediaStorage\thumbnails through the MEDIA_STORAGE_DIR bind.
THUMBNAILS_DIR=/app/media/thumbnails

# M4 — Whisper local STT (worker container). Defaults fit RTX 2070 8 GB.
# Set WHISPER_FAKE=1 on a non-GPU dev box / in CI to swap in a deterministic
# canned zh-Hant transcript and exercise the rest of the pipeline.
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=int8_float16
WHISPER_DEVICE=cuda
WHISPER_FAKE=0

# M4 — Vision frame sampling. The service caps total frames per asset to 60
# regardless of interval, so very long clips don't blow the Vision quota.
SCENE_SAMPLE_INTERVAL_MS=5000
