# Base URL for the media-processor backend API.
#
# Leave unset in dev — the vite dev server proxies /api to http://localhost:8623
# (configured in web/vite.config.ts), so the default "/api" works out of the box.
#
# Set this for production builds or non-proxied dev (e.g. running the SPA on a
# different host than the backend). When pointing at a separate origin in dev,
# you must also enable CORS on the FastAPI side.
#
# VITE_API_URL=http://localhost:8623
